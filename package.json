{
  "name": "vscode-scoped-commits",
  "displayName": "%extension.name%",
  "description": "Scope-first commit messages for VSCode.",
  "icon": "assets/icon.png",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.44.0"
  },
  "categories": [
    "Snippets",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "commit",
    "scoped-commits",
    "scope"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vivaxy/vscode-conventional-commits.git"
  },
  "author": "vivaxy",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vivaxy/vscode-conventional-commits/issues"
  },
  "homepage": "https://github.com/vivaxy/vscode-conventional-commits",
  "activationEvents": [
    "onCommand:extension.scopedCommits",
    "onCommand:extension.scopedCommits.resetGlobalState",
    "onCommand:extension.scopedCommits.showNewVersionNotes"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.scopedCommits",
        "title": "%extension.name%",
        "icon": {
          "dark": "./assets/menu-icon-dark.svg",
          "light": "./assets/menu-icon-light.svg"
        }
      },
      {
        "command": "extension.scopedCommits.resetGlobalState",
        "title": "%extension.commands.resetGlobalState%"
      },
      {
        "command": "extension.scopedCommits.showNewVersionNotes",
        "title": "%extension.commands.showNewVersionNotes%"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "extension.scopedCommits",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "%extension.name%",
      "properties": {
        "scopedCommits.autoCommit": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%extension.configuration.autoCommit.markdownDescription%"
        },
        "scopedCommits.storeScopesGlobally": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.storeScopesGlobally.markdownDescription%"
        },
        "scopedCommits.storeTagsGlobally": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.storeTagsGlobally.markdownDescription%"
        },
        "scopedCommits.silentAutoCommit": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.silentAutoCommit.markdownDescription%"
        },
        "scopedCommits.emojiFormat": {
          "type": "string",
          "default": "code",
          "markdownDescription": "%extension.configuration.emojiFormat.markdownDescription%",
          "enum": [
            "code",
            "emoji"
          ],
          "markdownEnumDescriptions": [
            "%extension.configuration.emojiFormat.markdownEnumDescriptions.code%",
            "%extension.configuration.emojiFormat.markdownEnumDescriptions.emoji%"
          ]
        },
        "scopedCommits.gitmoji": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.gitmoji.markdownDescription%"
        },
        "scopedCommits.lineBreak": {
          "type": "string",
          "default": "",
          "markdownDescription": "%extension.configuration.lineBreak.markdownDescription%"
        },
        "scopedCommits.promptBody": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%extension.configuration.promptBody.markdownDescription%"
        },
        "scopedCommits.promptCI": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.promptCI.markdownDescription%"
        },
        "scopedCommits.promptFooter": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%extension.configuration.promptFooter.markdownDescription%"
        },
        "scopedCommits.scopes": {
          "type": "array",
          "default": [],
          "markdownDescription": "%extension.configuration.scopes.markdownDescription%"
        },
        "scopedCommits.promptTag": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.promptTag.markdownDescription%"
        },
        "scopedCommits.tags": {
          "type": "array",
          "default": [],
          "markdownDescription": "%extension.configuration.tags.markdownDescription%"
        },
        "scopedCommits.showEditor": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.showEditor.markdownDescription%"
        },
        "scopedCommits.showNewVersionNotes": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%extension.configuration.showNewVersionNotes.markdownDescription%"
        },
        "scopedCommits.editor.keepAfterSave": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.configuration.editor.keepAfterSave.markdownDescription%"
        }
      }
    }
  },
  "scripts": {
    "dev": "node scripts/dev-vscode.js",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node prepare.js && vsce package --no-dependencies",
    "_build": "vsce package --no-dependencies",
    "prepare": "husky",
    "test": "vitest run",
    "test:e2e": "pnpm webpack && tsc -p e2e-test && node ./e2e-test/out/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.44.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "glob": "^13.0.0",
    "husky": "9",
    "lint-staged": "^17.0.0",
    "mocha": "^11.0.0",
    "prettier": "^3.0.0",
    "string-replace-loader": "^3.0.1",
    "ts-loader": "^9.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0",
    "warnings-to-errors-webpack-plugin": "^2.0.1",
    "webpack": "^5.76.0",
    "webpack-cli": "^7.0.0"
  },
  "lint-staged": {
    "*.{js,ts,css,less,json,md,html,yml,yaml,pcss,jsx,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/load": "^21.0.0",
    "@commitlint/rules": "^21.0.0",
    "@yi-xu-0100/conventional-commit-types-i18n": "1.6.0"
  }
}
